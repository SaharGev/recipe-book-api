    "testUserModel": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/userModel.test.ts",
    "testLike": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/like.test.ts",
    "testComment": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/comment.test.ts",
    "testUpload": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/upload.test.ts",
    "testUser": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/user.test.ts",
    "testAi": "tsc && jest --runInBand --detectOpenHandles --forceExit ./src/tests/ai.test.ts",
